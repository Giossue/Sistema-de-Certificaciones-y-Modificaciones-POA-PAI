{
  "name": "sistema-poa-pai",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"bun run --cwd apps/api dev\" \"bun run --cwd apps/web dev\"",
    "build": "bun run --cwd apps/web build && bun run --cwd apps/api build",
    "test": "bun run --cwd apps/api test",
    "lint": "eslint apps packages --ext .ts,.tsx",
    "db:migrate": "bun run --cwd apps/api prisma migrate dev",
    "db:seed": "bun run --cwd apps/api prisma db seed",
    "db:generate": "bun run --cwd apps/api prisma generate"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^17.6.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@heroui/react": "3.0.3",
    "lucide-react": "^1.14.0"
  }
}
