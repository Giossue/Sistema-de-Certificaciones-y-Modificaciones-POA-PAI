# Database
DATABASE_URL="postgresql://poa_user:poa_password@localhost:5432/poa_db?schema=public"

# JWT
JWT_SECRET="change-this-to-a-256-bit-secret-in-production"
JWT_EXPIRES_IN="8h"

# API
API_PORT=3001
API_HOST="0.0.0.0"

# Frontend
WEB_PORT=5173

# Environment
NODE_ENV="development"

# Storage
UPLOAD_DIR="./storage/uploads"
GENERATED_DIR="./storage/generated"
